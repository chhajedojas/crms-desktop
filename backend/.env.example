# Database Configuration
DATABASE_PATH=./data/crms.db
DATABASE_BACKUP_PATH=./data/backups
DATABASE_DUCKDB_PATH=./data/crms_analytics.duckdb

# IPC Configuration
IPC_MODE=stdio
IPC_HOST=127.0.0.1
IPC_PORT=8000
IPC_TIMEOUT=300
IPC_BUFFER_SIZE=65536

# OCR Configuration
OCR_ENABLED=true
OCR_LANGUAGE=eng
OCR_TESSERACT_PATH=/usr/local/bin/tesseract
OCR_TESSDATA_PATH=/usr/local/share/tessdata

# File Processing
MAX_FILE_SIZE_MB=100
SUPPORTED_FILE_TYPES=pdf,xlsx,xls,docx,doc,jpg,jpeg,png,tiff,bmp
CHUNK_SIZE=8192

# Classification
AUTO_CLASSIFY_ENABLED=true
CLASSIFICATION_MODEL_PATH=./models/classifier.pkl
CLASSIFICATION_CONFIDENCE_THRESHOLD=0.7

# Reorganization
DEFAULT_FOLDER_TEMPLATE=standard
FINANCIAL_YEAR_START=04-01
CREATE_UNDO_POINTS=true

# Logging
LOG_LEVEL=INFO
LOG_PATH=./logs
LOG_ROTATION=10 MB
LOG_RETENTION=30 days

# Cache
CACHE_ENABLED=true
CACHE_TTL=3600
CACHE_MAX_SIZE=1000

# Performance
INDEXING_THREADS=4
BATCH_SIZE=100
PARALLEL_PROCESSING=true

# Job Queue
JOB_QUEUE_ENABLED=true
JOB_QUEUE_REDIS_URL=redis://localhost:6379/0
JOB_QUEUE_CELERY_BROKER_URL=redis://localhost:6379/0
JOB_QUEUE_CELERY_RESULT_BACKEND=redis://localhost:6379/0
JOB_QUEUE_MAX_RETRIES=3
JOB_QUEUE_RETRY_BACKOFF=60
JOB_QUEUE_WORKER_CONCURRENCY=4

# Analytics
ANALYTICS_ENABLED=true
ANALYTICS_CACHE_SIZE_MB=1024
ANALYTICS_THREADS=2
